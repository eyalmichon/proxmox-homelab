#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────────────────────
# homelab — unified service management for the Docker host LXC
#
# Usage:  homelab <command> [args]
#         homelab help
# ──────────────────────────────────────────────────────────────────────────────
set -euo pipefail

# ── Colors / output helpers ──────────────────────────────────────────────────
GN="\033[1;32m" YW="\033[33m" BL="\033[36m" RD="\033[01;31m" BD="\033[1m" CL="\033[m"
header() { echo -e "\n${BL}──── $1 ────${CL}"; }
msg()    { echo -e " ${GN}✓${CL} $1"; }
info()   { echo -e " ${YW}→${CL} $1"; }
err()    { echo -e " ${RD}✗ $1${CL}" >&2; exit 1; }
warn()   { echo -e " ${YW}! $1${CL}" >&2; }

# ── Service registry & constants ─────────────────────────────────────────────
declare -A REGISTRY=(
  [nanit-bridge]="https://github.com/eyalmichon/nanit-bridge.git"
  [magic-files]="https://github.com/eyalmichon/magic-files.git"
)

SERVICES_DIR="${SERVICES_DIR:-/opt/services}"
BACKUPS_DIR="${BACKUPS_DIR:-/opt/backups}"
SELF_URL="https://raw.githubusercontent.com/eyalmichon/proxmox-homelab/main/homelab"

# ── Utility functions ────────────────────────────────────────────────────────

require_root() {
  [[ $(id -u) -eq 0 ]] || err "Run as root."
}

require_cmd() {
  command -v "$1" &>/dev/null || err "'$1' is required but not installed."
}

require_compose() {
  require_cmd docker
  docker compose version &>/dev/null || err "Docker Compose plugin is required."
}

require_service_arg() {
  [[ -n "${1:-}" ]] || err "Usage: homelab $COMMAND <service>"
}

validate_service_name() {
  [[ "$1" =~ ^[a-zA-Z0-9_-]+$ ]] || err "Invalid service name '$1'. Only letters, digits, hyphens, and underscores allowed."
}

parse_service_arg() {
  local arg="${1:-}"
  SVC="${arg%%@*}"
  VERSION="${arg#*@}"
  if [[ "$VERSION" == "$arg" ]]; then VERSION=""; fi
  [[ -n "$SVC" ]] && validate_service_name "$SVC"
  return 0
}

current_ref() {
  local dir="$(service_dir "$1")"
  local tag
  tag=$(git -C "$dir" describe --tags --exact-match 2>/dev/null) && { echo "$tag"; return; }
  git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "-"
}

service_dir() {
  echo "$SERVICES_DIR/$1"
}

trim() {
  local s="$1"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s\n' "$s"
}

is_installed() {
  local dir="$SERVICES_DIR/$1"
  [[ -d "$dir" ]] && [[ -f "$dir/.homelab-installed" || -f "$dir/docker-compose.yml" ]]
}

maybe_stamp_marker() {
  local dir="$(service_dir "$1")"
  [[ -f "$dir/.homelab-installed" ]] && return 0
  if [[ -f "$dir/docker-compose.yml" ]] && compose "$1" ps -q 2>/dev/null | grep -q .; then
    touch "$dir/.homelab-installed"
    info "Migrated '$1' to new install tracking"
  else
    warn "'$1' looks incomplete — run 'homelab install $1' to finish setup"
    return 1
  fi
}

require_installed() {
  is_installed "$1" || err "'$1' is not installed. Run: homelab install $1"
}

compose() {
  local dir="$SERVICES_DIR/$1"; shift
  docker compose -f "$dir/docker-compose.yml" --project-directory "$dir" "$@"
}

run_hook() {
  local script="$(service_dir "$1")/scripts/$2"
  if [[ -f "$script" ]]; then
    info "Running $2 …"
    bash "$script"
  fi
}

# Read user input from /dev/tty (safe inside redirected loops).
# Usage: prompt_user VARNAME "prompt text" [--secret]
prompt_user() {
  local -n _result=$1
  local prompt="$2"
  local -a flags=(-r)
  [[ "${3:-}" == "--secret" ]] && flags+=(-s)
  read "${flags[@]}" -p "  ${prompt}: " _result </dev/tty
  if [[ "${3:-}" == "--secret" ]]; then echo; fi
}

installed_services() {
  for d in "$SERVICES_DIR"/*/; do
    if [[ -f "$d/.homelab-installed" || -f "$d/docker-compose.yml" ]]; then
      basename "$d"
    fi
  done
}

# Resolve target list: specific service arg, or all installed.
resolve_targets() {
  local -n _targets=$1
  if [[ -n "${2:-}" ]]; then
    _targets=("$2")
  else
    mapfile -t _targets < <(installed_services)
    [[ ${#_targets[@]} -gt 0 ]] || err "No services installed."
    info "Targeting all services: ${_targets[*]}"
  fi
}

dotenv_escape() {
  local v="$1"
  v="${v//\\/\\\\}"
  v="${v//\"/\\\"}"
  v="${v//\$/\\\$}"
  printf '%s\n' "$v"
}

# ── .env.example parser ─────────────────────────────────────────────────────

generate_env() {
  local svc="$1"
  local dir="$(service_dir "$svc")"
  local example="$dir/.env.example"
  local target="$dir/.env"

  if [[ ! -f "$example" ]]; then
    warn "No .env.example found — skipping .env generation"
    return 0
  fi

  if [[ -f "$target" ]]; then
    local ans
    prompt_user ans ".env already exists. Overwrite? [y/N]"
    [[ "${ans,,}" == "y" ]] || return 0
  fi

  header "Configure $svc"
  local section="required"
  local env_lines=()

  while IFS= read -r line <&3 || [[ -n "$line" ]]; do
    if [[ "$line" =~ ^#\ *[Rr]equired ]]; then section="required"; continue; fi
    if [[ "$line" =~ ^#\ *[Oo]ptional ]]; then section="optional"; continue; fi
    [[ -z "$line" ]] && continue

    local commented=false
    local work="$line"

    if [[ "$work" =~ ^#\ *([A-Za-z_][A-Za-z0-9_]*=) ]]; then
      commented=true
      work="$(trim "${work#\#}")"
    fi

    [[ "$work" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*) ]] || continue

    local key="${BASH_REMATCH[1]}"
    local rest="${BASH_REMATCH[2]}"
    local default="" description=""

    if [[ "$rest" =~ ^([^#]*)#\ *(.*) ]]; then
      default="${BASH_REMATCH[1]}"
      description="${BASH_REMATCH[2]}"
    else
      default="$rest"
    fi
    default="$(trim "$default")"

    local prompt_text="$key"
    [[ -n "$description" ]] && prompt_text="$key ($description)"
    [[ -n "$default" ]] && prompt_text="$prompt_text [$default]"

    local secret_flag=""
    if [[ "${key,,}" =~ password|secret|token|api.key ]] || \
       [[ "${description,,}" =~ password|secret|token|api.key ]]; then
      secret_flag="--secret"
    fi

    local value=""
    if [[ "$section" == "required" && "$commented" == false ]]; then
      while true; do
        prompt_user value "$prompt_text" $secret_flag
        value="${value:-$default}"
        [[ -n "$value" ]] && break
        warn "Required — cannot be empty"
      done
    else
      prompt_user value "$prompt_text" $secret_flag
      value="${value:-$default}"
    fi

    env_lines+=("$key=\"$(dotenv_escape "$value")\"")
  done 3< "$example"

  printf '%s\n' "${env_lines[@]}" > "$target"
  chmod 600 "$target"
  msg ".env written (${#env_lines[@]} variables)"
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_install() {
  require_cmd git
  require_compose
  parse_service_arg "${1:-}"
  local svc="$SVC" version="$VERSION"
  require_service_arg "$svc"

  local repo="${REGISTRY[$svc]:-}"
  [[ -n "$repo" ]] || err "Unknown service '$svc'. Known: ${!REGISTRY[*]}"

  local dest="$(service_dir "$svc")"
  local resuming=false

  if [[ -d "$dest" ]]; then
    if compose "$svc" ps -q 2>/dev/null | grep -q .; then
      if [[ -f "$dest/.homelab-installed" ]]; then
        err "'$svc' is already running at $dest. Use 'homelab update $svc' instead."
      fi
      info "Stopping incomplete containers …"
      compose "$svc" down || true
    fi
    info "Found existing directory at $dest — resuming install"
    resuming=true
  fi

  header "Installing $svc${version:+ @ $version}"

  local git_out
  if $resuming; then
    if [[ -n "$version" ]]; then
      info "Fetching $version …"
      if git_out=$(git -C "$dest" fetch --depth 1 origin tag "$version" 2>&1) \
         && git_out+=$'\n'$(git -C "$dest" checkout "$version" 2>&1); then
        msg "Checked out $version"
      else
        echo "$git_out" >&2
        err "git checkout failed for $svc@$version"
      fi
    else
      info "Pulling latest …"
      if git_out=$(git -C "$dest" pull --ff-only 2>&1); then
        msg "Repository updated"
      else
        echo "$git_out" >&2
        err "git pull failed for $svc"
      fi
    fi
  else
    local -a clone_args=(--depth 1)
    [[ -n "$version" ]] && clone_args+=(--branch "$version")

    info "Cloning $repo${version:+ @ $version} …"
    if git_out=$(git clone "${clone_args[@]}" "$repo" "$dest" 2>&1); then
      msg "Cloned to $dest"
    else
      echo "$git_out" >&2
      err "git clone failed for $svc"
    fi
  fi

  [[ -f "$dest/docker-compose.yml" ]] || err "Repo missing docker-compose.yml — not a compatible service."

  generate_env "$svc"
  run_hook "$svc" "post-install.sh"

  info "Starting containers …"
  compose "$svc" pull 2>/dev/null || true
  compose "$svc" up -d
  touch "$dest/.homelab-installed"
  msg "$svc installed and running"

  local notes="$dest/INSTALL_NOTES"
  if [[ -f "$notes" ]]; then
    echo ""
    cat "$notes"
  fi
}

cmd_update() {
  require_cmd git
  require_compose
  local raw="${1:-}"
  parse_service_arg "$raw"
  local version="$VERSION"
  local targets=()
  resolve_targets targets "${SVC:-}"

  for svc in "${targets[@]}"; do
    require_installed "$svc"
    local dest="$(service_dir "$svc")"

    if ! maybe_stamp_marker "$svc"; then
      continue
    fi

    header "Updating $svc${version:+ → $version}"

    local git_out
    if [[ -n "$version" ]]; then
      info "Fetching $version …"
      if git_out=$(git -C "$dest" fetch --depth 1 origin tag "$version" 2>&1) \
         && git_out+=$'\n'$(git -C "$dest" checkout "$version" 2>&1); then
        msg "Checked out $version"
      else
        echo "$git_out" >&2
        err "git checkout failed for $svc@$version"
      fi
    else
      info "Pulling latest …"
      if git_out=$(git -C "$dest" pull --ff-only 2>&1); then
        msg "Repository updated"
      else
        echo "$git_out" >&2
        err "git pull failed for $svc"
      fi
    fi

    run_hook "$svc" "post-update.sh"

    info "Rebuilding containers …"
    compose "$svc" pull 2>/dev/null || true
    compose "$svc" up -d --build
    msg "$svc updated"
  done
}

cmd_remove() {
  require_compose
  local svc="${1:-}"
  require_service_arg "$svc"
  require_installed "$svc"

  local confirm
  prompt_user confirm "Remove '$svc'? This will stop its containers. [y/N]"
  [[ "${confirm,,}" == "y" ]] || { info "Aborted."; return 0; }

  header "Removing $svc"

  run_hook "$svc" "pre-remove.sh"

  local rm_vols
  prompt_user rm_vols "Also remove Docker volumes? [y/N]"
  if [[ "${rm_vols,,}" == "y" ]]; then
    compose "$svc" down -v
  else
    compose "$svc" down
  fi
  msg "Containers stopped"

  local dest="$(service_dir "$svc")"
  local del_dir
  prompt_user del_dir "Delete the repo directory $dest? [y/N]"
  if [[ "${del_dir,,}" == "y" ]]; then
    rm -rf "$dest"
    msg "Directory removed"
  else
    rm -f "$dest/.homelab-installed"
    info "Directory kept at $dest"
  fi

  msg "$svc removed"
}

cmd_status() {
  require_compose
  require_cmd jq
  header "Service Status"

  local services
  mapfile -t services < <(installed_services)

  if [[ ${#services[@]} -eq 0 ]]; then
    info "No services installed. Run: homelab install <service>"
    return 0
  fi

  printf "\n ${BD}%-20s %-10s %-12s %-10s %-12s %s${CL}\n" "SERVICE" "VERSION" "STATE" "HEALTH" "UPTIME" "PORTS"
  printf " %-20s %-10s %-12s %-10s %-12s %s\n" "-------" "-------" "-----" "------" "------" "-----"

  for svc in "${services[@]}"; do
    local ref
    ref=$(current_ref "$svc")

    local json
    json=$(compose "$svc" ps --format json 2>/dev/null) || true

    if [[ -z "$json" || "$json" == "[]" ]]; then
      printf " %-20s %-10s ${RD}%-12s${CL} %-10s %-12s %s\n" "$svc" "$ref" "stopped" "-" "-" "-"
      continue
    fi

    while IFS= read -r obj; do
      [[ -z "$obj" ]] && continue

      local name state health_val running_for published
      name=$(jq -r '.Name // empty' <<< "$obj")
      state=$(jq -r '.State // empty' <<< "$obj")
      health_val=$(jq -r '.Health // empty' <<< "$obj")
      running_for=$(jq -r '.RunningFor // empty' <<< "$obj")
      published=$(jq -r '[.Publishers[]?.PublishedPort // empty | select(. > 0)] | unique | map(tostring) | join(",")' <<< "$obj")

      [[ -z "$health_val" ]] && health_val="-"
      [[ -z "$running_for" ]] && running_for="-"
      [[ -z "$published" ]] && published="-"

      local color="$GN"
      [[ "$state" == "running" ]] || color="$RD"

      printf " %-20s %-10s ${color}%-12s${CL} %-10s %-12s %s\n" \
        "${name:-$svc}" "$ref" "$state" "$health_val" "$running_for" "$published"
    done <<< "$json"
  done
  echo
}

cmd_logs() {
  require_compose
  local svc="${1:-}"
  require_service_arg "$svc"
  require_installed "$svc"
  shift
  compose "$svc" logs "$@"
}

cmd_restart() {
  require_compose
  local svc="${1:-}"
  require_service_arg "$svc"
  require_installed "$svc"

  header "Restarting $svc"
  compose "$svc" restart
  msg "$svc restarted"
}

cmd_backup() {
  require_compose
  require_cmd jq
  local targets=()
  resolve_targets targets "${1:-}"

  for svc in "${targets[@]}"; do
    require_installed "$svc"
    header "Backing up $svc"

    local volumes
    # --volumes may fail if compose file is invalid; treat as "no volumes"
    volumes=$(compose "$svc" config --volumes 2>/dev/null) || true

    if [[ -z "$volumes" ]]; then
      info "No named volumes for $svc — skipping"
      continue
    fi

    docker image inspect alpine &>/dev/null || {
      info "Pulling alpine image (first-time only) …"
      docker pull alpine
    }

    local date_tag
    date_tag=$(date +%Y%m%d-%H%M%S)
    local backup_dir="$BACKUPS_DIR/$svc"
    mkdir -p "$backup_dir"

    local project
    project=$(compose "$svc" config --format json 2>/dev/null | jq -r '.name // empty')
    [[ -z "$project" ]] && project="$svc"

    while IFS= read -r vol; do
      [[ -z "$vol" ]] && continue
      local full_vol="${project}_${vol}"
      if ! docker volume inspect "$full_vol" &>/dev/null; then
        full_vol="$vol"
        if ! docker volume inspect "$full_vol" &>/dev/null; then
          warn "Volume $vol not found — skipping"
          continue
        fi
      fi
      local archive="$backup_dir/${vol}_${date_tag}.tar.gz"

      info "Backing up volume $full_vol …"
      docker run --rm \
        -v "${full_vol}:/data:ro" \
        -v "$backup_dir:/backup" \
        alpine tar czf "/backup/${vol}_${date_tag}.tar.gz" -C /data . \
        && msg "Saved $archive" \
        || warn "Failed to back up $full_vol"
    done <<< "$volumes"
  done
}

cmd_list() {
  require_cmd git
  header "Installed Services"

  local services
  mapfile -t services < <(installed_services)

  if [[ ${#services[@]} -eq 0 ]]; then
    info "No services installed."
    echo
    info "Available:"
    for name in "${!REGISTRY[@]}"; do
      echo -e "   ${BL}$name${CL}  →  ${REGISTRY[$name]}"
    done
    echo
    return 0
  fi

  printf "\n ${BD}%-20s %-10s %s${CL}\n" "SERVICE" "VERSION" "REPO"
  printf " %-20s %-10s %s\n" "-------" "-------" "----"

  for svc in "${services[@]}"; do
    local ref remote
    ref=$(current_ref "$svc")
    remote=$(git -C "$(service_dir "$svc")" remote get-url origin 2>/dev/null || echo "-")
    printf " %-20s %-10s %s\n" "$svc" "$ref" "$remote"
  done
  echo
}

cmd_versions() {
  require_cmd git
  local svc="${1:-}"
  require_service_arg "$svc"
  validate_service_name "$svc"

  local repo="${REGISTRY[$svc]:-}"
  [[ -n "$repo" ]] || err "Unknown service '$svc'. Known: ${!REGISTRY[*]}"

  header "Available versions for $svc"

  local tags
  tags=$(git ls-remote --tags --refs "$repo" 2>/dev/null \
    | sed 's|.*/||' | sort -rV)

  if [[ -z "$tags" ]]; then
    info "No tagged releases found. Use 'homelab install $svc' for latest main."
    return 0
  fi

  local current=""
  if is_installed "$svc"; then
    current=$(current_ref "$svc")
  fi

  while IFS= read -r tag; do
    if [[ "$tag" == "$current" ]]; then
      echo -e "  ${GN}$tag${CL}  ← installed"
    else
      echo "  $tag"
    fi
  done <<< "$tags"
  echo
}

cmd_self_update() {
  require_cmd wget
  header "Updating homelab CLI"
  local tmp
  tmp=$(mktemp)
  trap 'rm -f "$tmp"' RETURN
  wget -qO "$tmp" "$SELF_URL" || err "Download failed — check your internet connection"
  [[ -s "$tmp" ]] || err "Downloaded file is empty"
  head -1 "$tmp" | grep -q '^#!/' || err "Downloaded file is not a valid script"
  if cmp -s "$tmp" /usr/local/bin/homelab; then
    msg "Already up to date"
    return 0
  fi
  install -m 0755 "$tmp" /usr/local/bin/homelab
  msg "homelab CLI updated"
}

cmd_help() {
  echo -e "\n${BD}homelab${CL} — unified service management\n"
  echo "Usage:  homelab <command> [args]"
  echo ""
  printf "  ${GN}%-28s${CL} %s\n" "install <svc[@version]>" "Clone, configure, and start a service (pin to tag)"
  printf "  ${GN}%-28s${CL} %s\n" "update [svc[@version]]"  "Pull latest and rebuild (all if omitted)"
  printf "  ${GN}%-28s${CL} %s\n" "remove <service>"        "Stop and optionally delete a service"
  printf "  ${GN}%-28s${CL} %s\n" "status"                  "Show state of all services"
  printf "  ${GN}%-28s${CL} %s\n" "logs <service> [-f]"     "Tail service logs"
  printf "  ${GN}%-28s${CL} %s\n" "restart <service>"       "Restart a service"
  printf "  ${GN}%-28s${CL} %s\n" "backup [service]"        "Snapshot volumes to /opt/backups/"
  printf "  ${GN}%-28s${CL} %s\n" "list"                    "List installed services"
  printf "  ${GN}%-28s${CL} %s\n" "versions <service>"      "List available tagged releases"
  printf "  ${GN}%-28s${CL} %s\n" "self-update"             "Update the homelab CLI itself"
  printf "  ${GN}%-28s${CL} %s\n" "help"                    "Show this help"
  echo ""
  echo "Available services:"
  for name in $(echo "${!REGISTRY[@]}" | tr ' ' '\n' | sort); do
    echo -e "  ${BL}$name${CL}  →  ${REGISTRY[$name]}"
  done
  echo ""
}

# ── Main dispatch ────────────────────────────────────────────────────────────

[[ "${BASH_SOURCE[0]}" == "${0}" ]] || return 0

COMMAND="${1:-help}"
(( $# )) && shift

case "$COMMAND" in
  install)     require_root; cmd_install     "$@" ;;
  update)      require_root; cmd_update      "$@" ;;
  remove)      require_root; cmd_remove      "$@" ;;
  status)                    cmd_status      "$@" ;;
  logs)                      cmd_logs        "$@" ;;
  restart)     require_root; cmd_restart     "$@" ;;
  backup)      require_root; cmd_backup      "$@" ;;
  self-update) require_root; cmd_self_update "$@" ;;
  list)                      cmd_list        "$@" ;;
  versions)                  cmd_versions    "$@" ;;
  help|--help|-h)            cmd_help             ;;
  *) err "Unknown command '$COMMAND'. Run: homelab help" ;;
esac
